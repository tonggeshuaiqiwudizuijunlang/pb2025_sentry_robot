# =============================================================================
# .gitignore for ROS 2 / Colcon workspace (pb2025_sentry_robot)
# =============================================================================

# -----------------------------------------------------------------------------
# ROS 2 / Colcon build artifacts
# -----------------------------------------------------------------------------
build/
install/
log/
*.pyc
__pycache__/

# Colcon metadata
.colcon_*/

# -----------------------------------------------------------------------------
# CMake build artifacts
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile
CTestTestfile.cmake
_deps/
*.cmake
!*Config.cmake
!*-config.cmake
!*ConfigVersion.cmake

# -----------------------------------------------------------------------------
# Compiled binaries and libraries
# -----------------------------------------------------------------------------
*.o
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
*.egg-info/
dist/
*.egg
*.pyo
.pytest_cache/
.mypy_cache/

# -----------------------------------------------------------------------------
# IDE / Editor files
# -----------------------------------------------------------------------------
# VSCode
.vscode/
*.code-workspace

# CLion / JetBrains
.idea/
cmake-build-*/

# Eclipse CDT
.cproject
.project
.settings/

# Vim / Emacs swap files
*.swp
*.swo
*~
\#*\#
.\#*

# -----------------------------------------------------------------------------
# OS-specific files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
.directory

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Gazebo / simulation
# -----------------------------------------------------------------------------
# Gazebo model database cache
~/.gazebo/

# Simulation log files
*.log
gazebo_*.log

# -----------------------------------------------------------------------------
# ROS bags & large data files
# -----------------------------------------------------------------------------
*.bag
*.db3
*.bag.active
*.mcap

# -----------------------------------------------------------------------------
# SLAM / mapping outputs
# -----------------------------------------------------------------------------
maps/
*.pgm
*.yaml.bak
pointcloud_maps/
*.pcd

# -----------------------------------------------------------------------------
# Machine-learning model weights & datasets
# -----------------------------------------------------------------------------
*.onnx
# OpenVINO model description files (XML + binary pair)
*.bin
**/openvino_models/**/*.xml
*.weights
*.pt
*.pth
*.caffemodel
datasets/

# -----------------------------------------------------------------------------
# Hikvision / camera SDK artifacts
# -----------------------------------------------------------------------------
*.mvcfg

# -----------------------------------------------------------------------------
# Credentials & secrets
# -----------------------------------------------------------------------------
.env
*.key
*.pem
*.cert
secrets/

# -----------------------------------------------------------------------------
# Documentation build outputs
# -----------------------------------------------------------------------------
docs/_build/
doxygen_output/
html/
latex/

# -----------------------------------------------------------------------------
# Temporary / scratch files
# -----------------------------------------------------------------------------
tmp/
temp/
scratch/
*.tmp
*.bak
*.orig
